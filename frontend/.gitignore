# ==========================================
# Frontend .gitignore for React/Vite Project
# ==========================================

# ----------------------
# Section 1: Logs
# ----------------------
# Ignore log files generated by package managers
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------
# Section 2: Dependencies & Lockfiles
# ----------------------
# Ignore node_modules directory which can be huge and is generated from package.json
node_modules
# It's good practice to commit lock files for standard apps, but sometimes people ignore them.
# We'll leave them ignored based on your previous config.
pnpm-lock.yaml
package-lock.json

# ----------------------
# Section 3: Build & Cache
# ----------------------
# Ignore production output folders
dist
dist-ssr
*.local

# Ignore pnpm global store and tanstack router auto-generated cache
.pnpm-store/
.tanstack/*

# ----------------------
# Section 4: Environment Variables
# ----------------------
# Ignore local environment variable files
.env*
!.env.example

# ----------------------
# Section 5: IDEs & Editor Files
# ----------------------
# Ignore IDE specific folders and configuration
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----------------------
# Section 6: Testing
# ----------------------
# Vitest test coverage output and screenshots
/coverage
**/__screenshots__/
.vitest-attachments/
